# Egypt Alumin — Cloudflare Pages headers
# Documentation: https://developers.cloudflare.com/pages/configuration/headers/

# Global security headers (applied to everything)
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-XSS-Protection: 1; mode=block

# HTML pages — short cache, must revalidate
/*.html
  Cache-Control: public, max-age=300, must-revalidate

/
  Cache-Control: public, max-age=300, must-revalidate

/en/*
  Cache-Control: public, max-age=300, must-revalidate

/de/*
  Cache-Control: public, max-age=300, must-revalidate

# Static assets — long cache, immutable
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Images (when added) — long cache
/images/*
  Cache-Control: public, max-age=31536000, immutable

# SEO files
/sitemap.xml
  Cache-Control: public, max-age=3600
  Content-Type: application/xml

/robots.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain

/llms.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain
