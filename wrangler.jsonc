{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "egyptalumin",
  "compatibility_date": "2026-05-31",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "egyptalumin-main/dist"
  },
  "build": {
    "command": "npm install --prefix egyptalumin-main && npm run build --prefix egyptalumin-main"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
