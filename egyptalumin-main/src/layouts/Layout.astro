---
interface Props {
  title: string;
  description?: string;
  lang?: 'en' | 'de' | 'fr' | 'it';
}

const { title, description = "Premium aluminium ingot manufacturer supplying A7, ADC12 and AL-Si alloy ingots to the European market. ISO 9001 certified. CBAM-ready. REACH compliant.", lang = 'en' } = Astro.props;

import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const consentText = {
  en: { text: 'We use only essential cookies to make this site work — no tracking, no advertising.', accept: 'Accept', link: 'Cookie Policy' },
  de: { text: 'Wir verwenden nur essenzielle Cookies, damit diese Website funktioniert — kein Tracking, keine Werbung.', accept: 'Akzeptieren', link: 'Cookie-Richtlinie' },
  fr: { text: 'Nous utilisons uniquement des cookies essentiels au fonctionnement du site — aucun suivi ni publicité.', accept: 'Accepter', link: 'Politique cookies' },
  it: { text: 'Utilizziamo solo cookie essenziali per il funzionamento del sito — nessun tracciamento o pubblicità.', accept: 'Accetta', link: 'Cookie Policy' },
};
const consent = consentText[lang] || consentText.en;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
		<meta name="theme-color" content="#192843" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
		<link rel="icon" href="/favicon.ico" sizes="32x32" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<meta name="generator" content={Astro.generator} />
		
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:locale" content={lang === 'en' ? 'en_IE' : lang === 'de' ? 'de_DE' : lang === 'fr' ? 'fr_FR' : 'it_IT'} />

		<!-- Typography -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400..900;1,9..144,400..900&family=Plus+Jakarta+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet" />
	</head>
	<body>
		<Header lang={lang} />
		<slot />
		<Footer lang={lang} />

		<div id="cookie-banner" class="cookie-banner" role="dialog" aria-label="Cookie notice" hidden>
			<p>{consent.text} <a href="/en/cookie-policy/">{consent.link}</a></p>
			<button id="cookie-accept" class="btn btn-primary btn-sm" type="button">{consent.accept}</button>
		</div>

		<style>
			.cookie-banner {
				position: fixed; left: 1rem; right: 1rem; bottom: 1rem; z-index: 200;
				max-width: 600px; margin: 0 auto;
				background: var(--navy); color: #fff;
				border: 1px solid rgba(255,255,255,.14); border-radius: 12px;
				box-shadow: var(--shadow-lg); padding: 1rem 1.25rem;
				display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; justify-content: space-between;
			}
			.cookie-banner[hidden] { display: none; }
			.cookie-banner p { margin: 0; font-size: .85rem; line-height: 1.5; color: rgba(255,255,255,.85); flex: 1 1 300px; }
			.cookie-banner a { color: var(--gold-light); text-decoration: underline; }
			.cookie-banner .btn-primary { white-space: nowrap; }
		</style>

		<script>
			(function () {
				var KEY = 'ta-cookie-consent';
				var banner = document.getElementById('cookie-banner');
				if (!banner) return;
				try { if (localStorage.getItem(KEY) === '1') return; } catch (e) {}
				banner.hidden = false;
				var btn = document.getElementById('cookie-accept');
				if (btn) btn.addEventListener('click', function () {
					try { localStorage.setItem(KEY, '1'); } catch (e) {}
					banner.hidden = true;
				});
			})();
		</script>
	</body>
</html>
