---
interface Props {
  lang?: 'en' | 'de' | 'fr' | 'it';
}

const { lang = 'en' } = Astro.props;

const t = {
  en: {
    description: "Premium aluminium ingot manufacturer supplying A7, ADC12 and AL-Si alloy ingots to the European market. ISO 9001 certified. CBAM-ready. REACH compliant.",
    productsHeader: "Products",
    companyHeader: "Company",
    resourcesHeader: "Resources",
    rights: "© 2026 Tech Aluminum. All rights reserved.",
    privacy: "Privacy Policy",
    cookies: "Cookie Policy",
    catalogue: "Full Catalogue (PDF)",
    
    // Links
    a7Url: "/en/products/a7-primary-aluminium-ingot/",
    adc12Url: "/en/products/adc12-die-casting-alloy/",
    alsiUrl: "/en/products/aluminium-silicon-alloy-ingot/",
    
    aboutUrl: "/en/about/",
    facilityUrl: "/en/about/#facility",
    noelUrl: "/en/about/#noel",
    sustainabilityUrl: "/en/sustainability/",

    cbamUrl: "/en/cbam-guide/",
    qualityUrl: "/en/quality/",
    logisticsUrl: "/en/logistics/",
    faqUrl: "/en/faq/",
    blogUrl: "/en/blog/",
    qualityLabel: "Quality & Compliance",
    logisticsLabel: "Logistics & Shipping",
    faqLabel: "FAQ",
    blogLabel: "Industry Insights",
  },
  de: {
    description: "Premium-Aluminiumbarren-Hersteller für A7-, ADC12- und AL-Si-Legierungsbarren für den europäischen Markt. ISO 9001 zertifiziert. CBAM-bereit. REACH-konform.",
    productsHeader: "Produkte",
    companyHeader: "Unternehmen",
    resourcesHeader: "Ressourcen",
    rights: "© 2026 Tech Aluminum. Alle Rechte vorbehalten.",
    privacy: "Datenschutzerklärung",
    cookies: "Cookie-Richtlinie",
    catalogue: "Gesamtkatalog (PDF)",
    
    a7Url: "/de/produkte/a7-primaer-aluminiummassel/",
    adc12Url: "/de/produkte/adc12-druckguss-legierung/",
    alsiUrl: "/de/produkte/aluminium-silizium-legierung/",
    
    aboutUrl: "/de/ueber-uns/",
    facilityUrl: "/de/ueber-uns/#facility",
    noelUrl: "/de/ueber-uns/#noel",
    sustainabilityUrl: "/de/nachhaltigkeit/",

    cbamUrl: "/de/cbam-leitfaden/",
    qualityUrl: "/de/qualitaet/",
    logisticsUrl: "/de/logistik/",
    faqUrl: "/de/faq/",
    blogUrl: "/de/blog/",
    qualityLabel: "Qualität & Compliance",
    logisticsLabel: "Logistik & Versand",
    faqLabel: "FAQ",
    blogLabel: "Brancheneinblicke",
  },
  fr: {
    description: "Fabricant de lingots d'aluminium de qualité supérieure fournissant des lingots A7, ADC12 et AL-Si pour le marché européen. Certifié ISO 9001. Prêt pour la CBAM. Conforme REACH.",
    productsHeader: "Produits",
    companyHeader: "Entreprise",
    resourcesHeader: "Ressources",
    rights: "© 2026 Tech Aluminum. Tous droits réservés.",
    privacy: "Politique de Confidentialité",
    cookies: "Politique relative aux cookies",
    catalogue: "Catalogue Complet (PDF)",
    
    a7Url: "/fr/produits/lingot-d-aluminium-primaire-a7/",
    adc12Url: "/fr/produits/alliage-de-moulage-sous-pression-adc12/",
    alsiUrl: "/fr/produits/alliage-aluminium-silicium-al-si/",
    
    aboutUrl: "/fr/",
    facilityUrl: "/fr/#facility",
    noelUrl: "/fr/#noel",
    sustainabilityUrl: "/en/sustainability/",

    cbamUrl: "/en/cbam-guide/",
    qualityUrl: "/en/quality/",
    logisticsUrl: "/en/logistics/",
    faqUrl: "/en/faq/",
    blogUrl: "/en/blog/",
    qualityLabel: "Qualité & Conformité",
    logisticsLabel: "Logistique & Livraison",
    faqLabel: "FAQ",
    blogLabel: "Informations sectorielles",
  },
  it: {
    description: "Produttore di lingotti di alluminio premium che fornisce lingotti A7, ADC12 e AL-Si al mercato europeo. Certificato ISO 9001. CBAM-ready. Conforme a REACH.",
    productsHeader: "Prodotti",
    companyHeader: "Azienda",
    resourcesHeader: "Risorse",
    rights: "© 2026 Tech Aluminum. Tutti i diritti riservati.",
    privacy: "Informativa sulla Privacy",
    cookies: "Cookie Policy",
    catalogue: "Catalogo Completo (PDF)",
    
    a7Url: "/it/prodotti/lingotto-di-alluminio-primario-a7/",
    adc12Url: "/it/prodotti/lega-pressofusione-adc12/",
    alsiUrl: "/it/prodotti/lega-alluminio-silicio-al-si/",
    
    aboutUrl: "/it/",
    facilityUrl: "/it/#facility",
    noelUrl: "/it/#noel",
