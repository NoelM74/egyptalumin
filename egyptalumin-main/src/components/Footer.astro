    logisticsLabel: "Logistica & Spedizioni",
    faqLabel: "FAQ",
    blogLabel: "Approfondimenti del settore",
  }
};

const labels = t[lang] || t.en;
---

<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-grid">

      <div class="footer-brand">
        <a href={lang === 'en' ? '/en/' : `/${lang}/`} class="brand" aria-label="Tech Aluminum" style="color:#fff">
          <img src="/images/branding/brand-logo-white-01.webp" alt="Tech Aluminum" width="220" height="88" style="height:44px;width:auto;display:block" />
        </a>
        <p>{labels.description}</p>
        <div class="footer-cert">
          <span>ISO 9001</span>
          <span>REACH Compliant</span>
          <span>CBAM Ready</span>
        </div>
      </div>

      <div class="footer-col">
        <h4>{labels.productsHeader}</h4>
        <ul>
          <li><a href={labels.a7Url}>A7 Primary Ingot</a></li>
          <li><a href={labels.adc12Url}>ADC12 Die-Casting Ingot</a></li>
          <li><a href={labels.alsiUrl}>AL-Si Alloy</a></li>
          <li><a href="/assets/product-catalogue.pdf" target="_blank">{labels.catalogue}</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>{labels.companyHeader}</h4>
        <ul>
          <li><a href={labels.aboutUrl}>{lang === 'de' ? 'Über Tech Aluminum' : lang === 'fr' ? "À propos de Tech Aluminum" : lang === 'it' ? 'Chi siamo' : 'About Tech Aluminum'}</a></li>
          <li><a href={labels.facilityUrl}>Our Facility</a></li>
          <li><a href={labels.noelUrl}>Noel Murphy</a></li>
          <li><a href={labels.sustainabilityUrl}>Sustainability</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>{labels.resourcesHeader}</h4>
        <ul>
          <li><a href={labels.cbamUrl}>{labels.cbamUrl.includes('cbam-leitfaden') ? 'CBAM-Leitfaden' : labels.cbamUrl.includes('guide-cbam') ? 'Guide de la CBAM' : 'CBAM Guide'}</a></li>
          <li><a href={labels.qualityUrl}>{labels.qualityLabel}</a></li>
          <li><a href={labels.logisticsUrl}>{labels.logisticsLabel}</a></li>
          <li><a href={labels.faqUrl}>{labels.faqLabel}</a></li>
          <li><a href={labels.blogUrl}>{labels.blogLabel}</a></li>
        </ul>
      </div>

    </div>

    <div class="footer-bottom">
      <div>{labels.rights} · <a href={`/${lang}/privacy-policy/`} style="color:rgba(255,255,255,.5)">{labels.privacy}</a> · <a href={`/${lang}/cookie-policy/`} style="color:rgba(255,255,255,.5)">{labels.cookies}</a></div>
      <div class="footer-lang">
        <a href="/en/" class={lang === 'en' ? 'active' : ''}>EN</a>
        <a href="/de/" class={lang === 'de' ? 'active' : ''}>DE</a>
        <a href="/fr/" class={lang === 'fr' ? 'active' : ''}>FR</a>
        <a href="/it/" class={lang === 'it' ? 'active' : ''}>IT</a>
      </div>
    </div>
  </div>
</footer>
