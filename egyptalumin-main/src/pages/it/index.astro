---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Lingotti di Alluminio Premium dall'Egitto all'Europa | Tech Aluminum" lang="it">
  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="hero" aria-label="Introduction">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-text-block">
          <span class="eyebrow on-dark">Lingotti di Alluminio · Egitto → Europa</span>
          <h1 class="hero-title">Lingotti di Alluminio Premium dall'Egitto all'Europa</h1>
          <p class="hero-sub">
            Conforme agli standard europei. Pronto per il CBAM. Contatto europeo diretto.
            Scelta affidabile per fonderie e produttori in Germania, Italia, Francia e Regno Unito.
          </p>
          <div class="hero-ctas">
            <a href="/it/contact/" class="btn btn-primary">
              Richiedi un preventivo
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
            <a href="/it/prodotti/" class="btn btn-secondary">Vedi i nostri prodotti</a>
          </div>
          <div class="hero-badges" aria-label="Key credentials">
            <span>Certificato ISO 9001</span>
            <span>Conforme REACH</span>
            <span>Pronto per il CBAM</span>
            <span>50.000+ Tonnellate / Anno</span>
          </div>
        </div>
        <div class="hero-visual" aria-hidden="true">
          <div class="hero-img-container">
            <img src="/images/hero/1.1-egypt-alumin-aluminium-ingot-production-facility.webp" alt="Aluminium Factory Production Line" class="hero-img-modern" />
            <div class="hero-overlay-gradient"></div>
            <div class="hero-img-badge">
              <strong>FACILITY TECH ALUMINUM</strong>
              <span>Fonderia all'avanguardia</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust bar -->
  <div class="trust-bar" aria-label="Credentials">
    <div class="container">
      <div class="trust-bar-inner">
        <span><i class="trust-dot"></i> Gestione della qualità ISO 9001</span>
        <span><i class="trust-dot"></i> Conforme REACH</span>
        <span><i class="trust-dot"></i> Pronto per il CBAM (2026)</span>
        <span><i class="trust-dot"></i> Fornitore in 30+ Paesi</span>
        <span><i class="trust-dot"></i> Fondato nel 2020</span>
      </div>
    </div>
  </div>

  <!-- ============================================================
       THE NOEL MURPHY SECTION
       ============================================================ -->
  <section class="metrics-section" aria-label="Key metrics">
    <div class="container">
      <div class="metrics-grid">
        <div class="metric-card">
          <div class="metric-num" data-target="50000">0<span class="unit">t</span></div>
          <div class="metric-label">Capacità Annua Attuale</div>
        </div>
        <div class="metric-card">
          <div class="metric-num" data-target="100000">0<span class="unit">t</span></div>
          <div class="metric-label">Espansione in corso</div>
        </div>
        <div class="metric-card">
          <div class="metric-num" data-target="30">0<span class="unit">+</span></div>
          <div class="metric-label">Paesi di Esportazione</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PRODUCTS
       ============================================================ -->
  <section class="products-section" id="products" aria-labelledby="products-heading">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Linee di Prodotti</span>
        <h2 id="products-heading">Tre linee di prodotti core, progettate per l'industria europea</h2>
        <p>Tutti i lingotti sono prodotti secondo gli standard europei con certificati di analisi e dati carbone completi.</p>
      </div>

      <div class="product-grid">
        <article class="product-card-modern">
          <div class="product-img-wrapper">
            <img src="/images/products/2.2-a7-aluminium-ingot-bundle-steel-strapped-palletised.webp" alt="A7 Ingot" class="product-img-asset" />
            <div class="product-img-overlay">
              <span class="product-img-label">Lingotto di Alluminio Primario A7 · 25 kg</span>
            </div>
          </div>
          <div class="product-body">
            <span class="product-tag">EN 576 · P1020A</span>
            <h3 class="product-title">Lingotto di Alluminio Primario A7</h3>
            <div class="product-specs">
              <span>Al ≥ 99.7%</span>
              <span>Lingotto da 25 kg</span>
              <span>Grado P1020A</span>
            </div>
            <p class="product-desc">La materia prima fondamentale per la lavorazione dell'alluminio — elevata purezza, impurità minime, pronto per la rifusione.</p>
            <a href="/it/contact/" class="product-link">Richiedi informazioni</a>
          </div>
        </article>

        <article class="product-card-modern">
          <div class="product-img-wrapper">
            <img src="/images/products/2.3-adc12-die-casting-aluminium-alloy-ingot-en-ac-46000.webp" alt="ADC12 Alloy" class="product-img-asset" />
            <div class="product-img-overlay">
              <span class="product-img-label">Lega da Fonderia ADC12 · 20 kg</span>
            </div>
          </div>
          <div class="product-body">
            <span class="product-tag">EN AC-46000 · AlSi9Cu3</span>
            <h3 class="product-title">Lega da Fonderia ADC12</h3>
            <div class="product-specs">
              <span>Si 9.6–12%</span>
              <span>Lingotto da 20 kg</span>
              <span>Ottima colabilità</span>
            </div>
            <p class="product-desc">La lega di fonderia a pressione standard per getti complessi e ad alta precisione.</p>
            <a href="/it/contact/" class="product-link">Richiedi informazioni</a>
          </div>
        </article>

        <article class="product-card-modern">
          <div class="product-img-wrapper">
            <img src="/images/products/2.4-aluminium-silicon-alloy-ingot-en-1706-precision-casting.webp" alt="AL-Si Alloy" class="product-img-asset" />
            <div class="product-img-overlay">
              <span class="product-img-label">Lega di Alluminio-Silicio AL-Si · 20 kg</span>
            </div>
          </div>
          <div class="product-body">
            <span class="product-tag">EN 1706 · AC-4xxxx</span>
            <h3 class="product-title">Lega di Alluminio-Silicio AL-Si</h3>
            <div class="product-specs">
              <span>Al ≥ 99.7% + Si</span>
              <span>Lingotto da 20 kg</span>
              <span>Massima fluidità</span>
            </div>
            <p class="product-desc">Lega formulata con precisione per un'eccellente fluidità negli stampi per componenti automobilistici e industriali.</p>
            <a href="/it/contact/" class="product-link">Richiedi informazioni</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FINAL CTA
       ============================================================ -->
  <section class="noel-section" id="noel-contact-section" aria-labelledby="noel-heading">
    <div class="container">
      <div class="noel-grid">
        <div class="noel-photo-wrapper" aria-hidden="true">
          <span class="noel-flag">
            <span class="flag-ie" aria-hidden="true"><span></span><span></span><span></span></span>
            Irlanda
          </span>
          <img src="/images/branding/brand-noel-murphy-portrait-01.webp" alt="Noel Murphy - Partner, European Operations" class="noel-img-modern" />
          <div class="noel-photo-overlay"></div>
        </div>

        <div class="noel-content">
          <span class="eyebrow">Il Tuo Contatto Europeo Diretto</span>
          <h2 id="noel-heading">Parla direttamente con il nostro partner europeo</h2>
          <p class="lead">
            Mi chiamo <strong>Noel Murphy</strong>, partner di Tech Aluminum e rappresentante europeo della nostra azienda.
            Con sede in Irlanda, ho aderito alla partnership per collegare la produzione di alluminio di livello mondiale in Egitto
            con gli standard rigorosi dei produttori europei.
          </p>
          <blockquote>
            Quando lavorate con Tech Aluminum, trattate direttamente con me — un uomo d'affari irlandese che
            comprende gli acquisti europei, le aspettative contrattuali e il vero significato di "affidabilità"
            per un acquirente italiano, tedesco o francese. Senza intermediari. Senza barriere linguistiche.
            <cite>— Noel Murphy, Partner — Operazioni Europee</cite>
          </blockquote>

          <div class="noel-contacts">
            <a class="noel-contact" href="https://wa.me/353871187806" aria-label="Chiama Noel Murphy">
              <span class="icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.9.31 1.78.57 2.62a2 2 0 0 1-.45 2.11L8 9.91a16 16 0 0 0 6 6l1.46-1.23a2 2 0 0 1 2.11-.45c.84.26 1.72.45 2.62.57A2 2 0 0 1 22 16.92z"/></svg>
              </span>
              <span><small>Telefono (Irlanda)</small><strong>WhatsApp</strong></span>
            </a>
            <a class="noel-contact" href="mailto:noel@techaluminum.com" aria-label="E-mail Noel Murphy">
              <span class="icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </span>
              <span><small>E-mail</small><strong>noel@techaluminum.com</strong></span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       METRICS
       ============================================================ -->

  <section class="final-cta" aria-labelledby="cta-heading">
    <div class="container">
      <span class="eyebrow on-dark">Sempre al tuo fianco</span>
      <h2 id="cta-heading">Discutiamo le tue esigenze di alluminio</h2>
      <p>Indicaci la lega, il tonnellaggio e il porto di destinazione — ti risponderemo entro 24 ore con le nostre quotazioni competitive.</p>
      <div class="final-cta-actions">
        <a href="/it/contact/" class="btn btn-primary">Richiedi un preventivo</a>
        <a href="https://wa.me/353871187806" class="btn btn-secondary">Discuti su WhatsApp</a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const metricsSection = document.querySelector('.metrics-section');
  const metricNums = document.querySelectorAll('.metric-num');

  if (metricsSection && metricNums.length > 0) {
    const animateCounters = () => {
      metricNums.forEach(num => {
        const target = parseInt(num.getAttribute('data-target') || '0', 10);
        const unit = num.querySelector('.unit')?.outerHTML || '';
        let start = 0;
        const duration = 1200; // ms
        const stepTime = Math.abs(Math.floor(duration / target)) || 10;
        
        const increment = target > 1000 ? Math.ceil(target / 100) : 1;

        const timer = setInterval(() => {
          start += increment;
          if (start >= target) {
            start = target;
            clearInterval(timer);
          }
          const formatted = start.toLocaleString();
          num.innerHTML = `${formatted}${unit}`;
        }, stepTime);
      });
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          animateCounters();
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    observer.observe(metricsSection);
  }
</script>

<style>
  .hero-img-container {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 5/4;
    box-shadow: var(--shadow-lg);
    border: 1px solid rgba(255, 255, 255, 0.12);
  }
  .hero-img-modern {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .hero-img-container:hover .hero-img-modern {
    transform: scale(1.05);
  }
  .hero-overlay-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(17, 29, 54, 0.8) 0%, rgba(17, 29, 54, 0.1) 60%, transparent 100%);
    pointer-events: none;
  }
  .hero-img-badge {
    position: absolute;
    bottom: 1.5rem;
    left: 1.5rem;
    color: var(--white);
    z-index: 2;
  }
  .hero-img-badge strong {
    display: block;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    color: var(--amber);
  }
  .hero-img-badge span {
    font-size: 0.8rem;
    opacity: 0.85;
  }

  .metrics-section {
    background: linear-gradient(180deg, var(--white) 0%, var(--silver-soft) 100%);
    padding: 5rem 0;
    border-bottom: 1px solid var(--border);
  }
  .metric-card {
    text-align: center;
    padding: 2.25rem 1.5rem;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .metric-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow);
    border-color: var(--teal);
  }

  .noel-photo-wrapper {
    position: relative;
    aspect-ratio: 4/5;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow);
    border: 1px solid var(--border);
  }
  .noel-img-modern {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .noel-photo-wrapper:hover .noel-img-modern {
    transform: scale(1.03);
  }
  .noel-photo-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(27,42,74,0.1) 0%, rgba(27,42,74,0.4) 100%);
    pointer-events: none;
  }

  .product-img-wrapper {
    position: relative;
    aspect-ratio: 16/10;
    overflow: hidden;
    background: var(--navy);
  }
  .product-img-asset {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.85;
    transition: transform 0.5s ease, opacity 0.5s ease;
  }
  .product-card-modern:hover .product-img-asset {
    transform: scale(1.06);
    opacity: 1;
  }
  .product-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 60%);
    display: flex;
    align-items: flex-end;
    padding: 1rem;
  }
  .product-card-modern {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .product-card-modern:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
    border-color: var(--teal);
  }
</style>
