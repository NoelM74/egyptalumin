          <p class="hero-sub">
            Conforme aux normes européennes. Prêt pour le MACF. Contact européen direct.
            Partenaire de confiance des fonderies et fabricants en Allemagne, Italie, France et au Royaume-Uni.
          </p>
          <div class="hero-ctas">
            <a href="/fr/contact/" class="btn btn-primary">
              Demander un devis
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
            <a href="/fr/produits/" class="btn btn-secondary">Voir nos produits</a>
          </div>
          <div class="hero-badges" aria-label="Key credentials">
            <span>Certifié ISO 9001</span>
            <span>Conforme REACH</span>
            <span>Prêt pour le MACF</span>
            <span>50 000+ Tonnes / An</span>
          </div>
        </div>
        <div class="hero-visual" aria-hidden="true">
          <div class="hero-img-container">
            <img src="/images/hero/1.1-egypt-alumin-aluminium-ingot-production-facility.webp" alt="Aluminium Factory Production Line" class="hero-img-modern" />
            <div class="hero-overlay-gradient"></div>
            <div class="hero-img-badge">
              <strong>FACILITÉ EGYPT ALUMIN</strong>
              <span>Fonderie de pointe</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust bar -->
  <div class="trust-bar" aria-label="Credentials">
    <div class="container">
      <div class="trust-bar-inner">
        <span><i class="trust-dot"></i> Gestion de la qualité ISO 9001</span>
        <span><i class="trust-dot"></i> Conforme REACH</span>
        <span><i class="trust-dot"></i> Prêt pour le MACF (2026)</span>
        <span><i class="trust-dot"></i> Fournisseur dans 30+ Pays</span>
        <span><i class="trust-dot"></i> Établi en 2020</span>
      </div>
    </div>
  </div>

  <!-- ============================================================
       THE NOEL MURPHY SECTION
       ============================================================ -->
