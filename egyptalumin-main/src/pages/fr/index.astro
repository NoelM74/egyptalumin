---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Lingots d'Aluminium Premium de l'Égypte vers l'Europe | Egypt Alumin" lang="fr">
  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="hero" aria-label="Introduction">
