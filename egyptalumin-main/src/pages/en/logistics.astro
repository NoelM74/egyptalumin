---
import Layout from '../../layouts/Layout.astro';
---

<Layout 
  title="B2B Logistics & Shipping Protocols | Tech Aluminum" 
  description="Authoritative logistical routes, port details, transit times, and customs documentation (EUR.1) for primary B2B aluminium imports from Egypt to Europe."
  lang="en"
>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <div class="container">
      <ol>
        <li><a href="/en/">Home</a></li>
        <li aria-current="page">Logistics & Shipping</li>
      </ol>
    </div>
  </nav>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="product-hero">
    <div class="container">
      <div class="product-hero-grid" style="grid-template-columns: 1fr;">
        <div style="text-align: center; max-width: 850px; margin: 0 auto;">
          <span class="eyebrow on-dark">Mediterranean Logistics Lanes</span>
          <h1 style="font-size: 3.2rem; margin-bottom: 1.2rem;">Direct Maritime Feedstock Supply</h1>
          <p class="product-hero-lead" style="font-size: 1.25rem;">
            Connecting primary Egyptian smelting directly with major European container ports. 
            Reliable schedules, duty-free transit, and comprehensive B2B customs clearance support.
          </p>
          <div class="product-hero-badges" style="justify-content: center; margin-top: 1.8rem;">
            <span>Alexandria & Damietta Hubs</span>
            <span>EUR.1 Duty-Free Certified</span>
            <span>10–24 Day Transit Times</span>
            <span>Full REACH Compliance</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       TRANSIT TIME GRID
       ============================================================ -->
  <section style="background: var(--white); padding: 5rem 0;">
    <div class="container">
      <div class="section-header" style="text-align:center; max-width:700px; margin: 0 auto 4rem auto;">
        <span class="eyebrow">Transit Schedules</span>
        <h2>Estimated Maritime Transit Times</h2>
        <p>Operating direct container shipping lines from Alexandria and Damietta ports to major European B2B receipt hubs.</p>
      </div>

      <div class="product-grid" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem;">
        <!-- South Europe -->
        <div style="background:var(--silver-soft); border: 1px solid var(--border); padding:2.5rem 2rem; border-radius:var(--radius-lg); text-align:center;">
          <div style="width: 50px; height: 50px; border-radius: 50%; background: rgba(0,123,95,0.1); display: grid; place-items: center; margin: 0 auto 1.5rem auto; color: var(--teal);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 style="font-family:'Plus Jakarta Sans',sans-serif; color:var(--teal); font-size: 2.2rem; margin-bottom: 0.5rem;">10–14 Days</h3>
          <strong>Southern Europe Ports</strong>
          <p style="font-size:0.9rem; margin-top:0.5rem; color:var(--ink-soft);">Direct lanes to Genoa (Italy), Barcelona (Spain), and Marseille (France).</p>
        </div>

        <!-- North Europe -->
        <div style="background:var(--silver-soft); border: 1px solid var(--border); padding:2.5rem 2rem; border-radius:var(--radius-lg); text-align:center;">
          <div style="width: 50px; height: 50px; border-radius: 50%; background: rgba(0,123,95,0.1); display: grid; place-items: center; margin: 0 auto 1.5rem auto; color: var(--teal);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <h3 style="font-family:'Plus Jakarta Sans',sans-serif; color:var(--teal); font-size: 2.2rem; margin-bottom: 0.5rem;">18–24 Days</h3>
          <strong>Northern Europe Ports</strong>
          <p style="font-size:0.9rem; margin-top:0.5rem; color:var(--ink-soft);">Direct lanes to Rotterdam (Netherlands), Hamburg (Germany), and Antwerp (Belgium).</p>
        </div>

        <!-- Eastern Europe -->
        <div style="background:var(--silver-soft); border: 1px solid var(--border); padding:2.5rem 2rem; border-radius:var(--radius-lg); text-align:center;">
          <div style="width: 50px; height: 50px; border-radius: 50%; background: rgba(0,123,95,0.1); display: grid; place-items: center; margin: 0 auto 1.5rem auto; color: var(--teal);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 20h20M5 17V5a3 3 0 0 1 3-3h8a3 3 0 0 1 3 3v12"/></svg>
          </div>
          <h3 style="font-family:'Plus Jakarta Sans',sans-serif; color:var(--teal); font-size: 2.2rem; margin-bottom: 0.5rem;">12–16 Days</h3>
          <strong>Central & East Europe</strong>
          <p style="font-size:0.9rem; margin-top:0.5rem; color:var(--ink-soft);">Routing via Koper (Slovenia) and Rijeka (Croatia) for regional rail forwarding.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       DOCUMENTATION & CUSTOMS
       ============================================================ -->
  <section style="background: var(--silver-soft); padding: 5rem 0;">
    <div class="container">
      <div class="cbam-inner" style="grid-template-columns: 1fr 1.1fr; gap: 4rem; align-items: center;">
        <div class="product-image" style="box-shadow:var(--shadow-lg);">
          <div class="product-img-container-inner" style="border-radius: var(--radius-lg); overflow: hidden;">
            <img src="/images/blog/6.6-shipping-aluminium-egypt-europe-logistics-guide.webp" alt="Cargo Ship Logistics" class="product-img-modern" style="width:100%; object-fit:cover;" />
          </div>
        </div>
        <div>
          <span class="eyebrow">Duty-Free Customs Clearance</span>
          <h2>Seamless Import Standards</h2>
          <p>
            Aluminium ingots and alloys originating from Egypt qualify for <strong>0% preferential customs import duty</strong> 
            under the EU-Egypt Association Agreement. 
          </p>
          <p>
            To ensure rapid customs clearance and avoid delay penalties, our logistics department provides the complete 
            standardized documentation suite with every shipment:
          </p>
          <ul style="padding-left:1.5rem; line-height:1.8; color:var(--ink-soft); margin:1.5rem 0;">
            <li><strong>EUR.1 Movement Certificate</strong> (to secure 0% tariff clearance)</li>
            <li><strong>REACH Compliance Declaration</strong> (fully pre-registered)</li>
            <li><strong>Bill of Lading</strong> (clean on board, master and house)</li>
            <li><strong>Certificate of Chemical Analysis</strong> (direct from smelter lab)</li>
            <li><strong>Commercial Invoice & Detailed Packing List</strong></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CONTAINER SPECIFICATIONS
       ============================================================ -->
  <section style="background: var(--white); padding: 5rem 0;">
    <div class="container">
      <div class="cbam-inner" style="grid-template-columns: 1.1fr 0.9fr; gap: 4rem; align-items: center;">
        <div>
          <span class="eyebrow">Cargo Parameters</span>
          <h2>Container & Loading Specifications</h2>
          <p>
            To maintain alloy integrity and prevent physical damage during maritime transit, all primary aluminium 
            bundles are securely strapped with heavy-duty steel bands and palletized.
          </p>
          <div style="margin:2rem 0; border-top: 1px solid var(--border);">
            <div style="display:flex; justify-content:space-between; padding: 1rem 0; border-bottom:1px solid var(--border);">
              <strong>Standard Ingot Bundle Weight:</strong>
              <span style="color:var(--teal); font-weight:600;">Approx. 1,000 kg</span>
            </div>
            <div style="display:flex; justify-content:space-between; padding: 1rem 0; border-bottom:1px solid var(--border);">
              <strong>Minimum Order Quantity (MOQ):</strong>
              <span style="color:var(--teal); font-weight:600;">20 Metric Tonnes (1 FCL)</span>
            </div>
            <div style="display:flex; justify-content:space-between; padding: 1rem 0; border-bottom:1px solid var(--border);">
              <strong>FCL Capacity (20-Foot Heavy):</strong>
              <span style="color:var(--teal); font-weight:600;">20 to 22 Metric Tonnes</span>
            </div>
            <div style="display:flex; justify-content:space-between; padding: 1rem 0; border-bottom:1px solid var(--border);">
              <strong>Packaging Options:</strong>
              <span style="color:var(--teal); font-weight:600;">Steel-strapped bundle / Wooden pallets</span>
            </div>
          </div>
        </div>
        <div class="product-image" style="box-shadow:var(--shadow-lg);">
          <div class="product-img-container-inner" style="border-radius: var(--radius-lg); overflow: hidden;">
            <img src="/images/hero/1.5-container-ship-mediterranean-port-aluminium-export.webp" alt="Loading Facility" class="product-img-modern" style="width:100%; object-fit:cover;" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FINAL CTA
       ============================================================ -->
  <section class="final-cta">
    <div class="container">
      <span class="eyebrow on-dark">Direct Logistics Desk</span>
      <h2>Discuss your shipping timeline</h2>
      <p>Whether you require specific scheduling, delivery duty paid (DDP/CIF) terms, or regular contract routing, speak directly with Noel Murphy.</p>
      <div class="final-cta-actions">
        <a href="/en/contact/" class="btn btn-primary">Request a Quote</a>
        <a href="https://wa.me/353871187806" class="btn btn-secondary">Message Noel on WhatsApp</a>
      </div>
      <p class="final-cta-direct">
        Direct Email: <a href="mailto:noel@techaluminum.com">noel@techaluminum.com</a> · WhatsApp: <a href="https://wa.me/353871187806">Direct Chat</a>
      </p>
    </div>
  </section>
</Layout>

<style>
  .product-img-container-inner {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 16/10;
    box-shadow: var(--shadow-lg);
    border: 1px solid rgba(0,0,0,0.08);
  }
  .product-img-modern {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .product-img-container-inner:hover .product-img-modern {
    transform: scale(1.03);
  }
</style>
