---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="Aluminium Ingots for Power Infrastructure & Rail | Egypt Alumin" lang="en">
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <div class="container"><ol>
      <li><a href="/en/">Home</a></li>
      <li><a href="/en/industries/">Industries</a></li>
      <li aria-current="page">Power & Transport</li>
    </ol></div>
  </nav>

  <section class="product-hero">
    <div class="container">
      <div class="product-hero-grid" style="grid-template-columns:1fr;">
        <div style="max-width:800px;">
          <span class="eyebrow on-dark">Industry Application</span>
          <h1>Aluminium for Power Infrastructure & Rail</h1>
          <p class="product-hero-lead">High-purity primary ingots for overhead cable conductors, power transmission components, and lightweight rail transit structures.</p>
          <div class="product-hero-ctas">
            <a href="/en/contact/" class="btn btn-primary">Request Specifications</a>
            <a href="/en/products/" class="btn btn-secondary">View All Products</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section style="padding:5rem 0;background:var(--warm-white);">
    <div class="container" style="max-width:820px;">
      <h2>Products for power and transport applications</h2>
      <p>Aluminium conductor alloys require precise silicon and iron content to hit target conductivity (IACS ratings) while maintaining tensile strength for overhead line applications. Rail transit structural components need consistent mechanical properties across long production runs.</p>
      <ul>
        <li><strong>A7 Primary Aluminium Ingot (EN 576)</strong> — 99.7% minimum purity with controlled Fe and Si maxima. The standard charge for AAAC (All Aluminium Alloy Conductor) and ACSR core wire production. Conductivity ≥ 61% IACS achievable from this feedstock.</li>
        <li><strong>AL-Si Alloy Ingot (EN 1706)</strong> — Used in precision castings for rail connector housings, pantograph components, and lightweight structural brackets.</li>
      </ul>
      <a href="/en/contact/" class="btn btn-primary" style="margin-top:1.5rem;display:inline-flex;">Request specifications →</a>
    </div>
  </section>

  <section class="final-cta">
    <div class="container">
      <h2>Sourcing aluminium for power or rail applications?</h2>
      <p>Noel Murphy handles all European enquiries. Response within 24 hours.</p>
      <div class="final-cta-actions">
        <a href="/en/contact/" class="btn btn-primary">Request a Quote</a>
        <a href="https://wa.me/353871187806" class="btn btn-secondary">WhatsApp</a>
      </div>
    </div>
  </section>
</Layout>
