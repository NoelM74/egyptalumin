---
import Layout from '../../../layouts/Layout.astro';
---

<Layout 
  title="Industries Served | Custom Aluminium Casting & Extrusion Feedstock" 
  description="Tech Aluminum supplies high-purity A7 ingots, ADC12, and AL-Si alloys to primary European B2B industries, including Automotive, Aerospace, Construction, and Electrical Grid infrastructure."
  lang="en"
>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <div class="container">
      <ol>
        <li><a href="/en/">Home</a></li>
        <li aria-current="page">Industries</li>
      </ol>
    </div>
  </nav>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="product-hero">
    <div class="container">
      <div style="text-align: center; max-width: 850px; margin: 0 auto;">
        <span class="eyebrow on-dark">Premium Feedstock for Global B2B Brands</span>
        <h1 style="font-size: 3.2rem; margin-bottom: 1.2rem;">Industries We Supply</h1>
        <p class="product-hero-lead" style="font-size: 1.25rem;">
          Providing certified chemical purity, reliable delivery schedules, and fully registered REACH/CBAM compliance 
          across Europe's highest-value manufacturing sectors.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       INDUSTRIES GRID
       ============================================================ -->
  <section style="background: var(--white); padding: 5rem 0;">
    <div class="container">
      <div class="product-grid" style="grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 2.5rem;">
        
        <!-- Automotive -->
        <div class="app-item" style="background:var(--silver-soft); border:1px solid var(--border); border-radius:var(--radius-lg); overflow:hidden; display:flex; flex-direction:column;">
          <div style="aspect-ratio:16/9; overflow:hidden;">
            <img src="/images/applications/4.2-aluminium-automotive-components-engine-parts-wheel-hub.webp" alt="Automotive and EV Components" style="width:100%; height:100%; object-fit:cover; transition:transform 0.4s ease;" class="product-img-modern" />
          </div>
          <div style="padding: 2rem; flex-grow:1; display:flex; flex-direction:column;">
            <h3 style="font-family:'Plus Jakarta Sans',sans-serif; margin-bottom:0.75rem;">Automotive & EV Structural Elements</h3>
            <p style="font-size:0.9rem; line-height:1.6; color:var(--ink-soft); margin-bottom:1.5rem;">
              Supplying ADC12 and highly ductile AL-Si alloys (AlSi7Mg) for EV battery enclosures, crash structures, engine blocks, and complex transmission housings.
            </p>
            <span style="font-size:0.85rem; font-weight:600; color:var(--teal); margin-top:auto;">Primary alloy: AL-Si & ADC12</span>
          </div>
        </div>

        <!-- Construction -->
        <div class="app-item" style="background:var(--silver-soft); border:1px solid var(--border); border-radius:var(--radius-lg); overflow:hidden; display:flex; flex-direction:column;">
          <div style="aspect-ratio:16/9; overflow:hidden;">
            <img src="/images/applications/4.4-aluminium-curtain-wall-facade-modern-building-construction.webp" alt="Construction Extrusions" style="width:100%; height:100%; object-fit:cover; transition:transform 0.4s ease;" class="product-img-modern" />
          </div>
          <div style="padding: 2rem; flex-grow:1; display:flex; flex-direction:column;">
            <h3 style="font-family:'Plus Jakarta Sans',sans-serif; margin-bottom:0.75rem;">Building, Architecture & Extrusions</h3>
            <p style="font-size:0.9rem; line-height:1.6; color:var(--ink-soft); margin-bottom:1.5rem;">
              Premium-purity A7 Primary Ingots (Al99.7%) destined for structural extrusion billets. Perfect for window frames, curtain walls, and sleek glassmorphic structural facades.
            </p>
            <span style="font-size:0.85rem; font-weight:600; color:var(--teal); margin-top:auto;">Primary alloy: A7 (99.7%)</span>
          </div>
        </div>

        <!-- Aerospace -->
        <div class="app-item" style="background:var(--silver-soft); border:1px solid var(--border); border-radius:var(--radius-lg); overflow:hidden; display:flex; flex-direction:column;">
          <div style="aspect-ratio:16/9; overflow:hidden;">
            <img src="/images/applications/4.3-aluminium-aerospace-aircraft-fuselage-structural-components.webp" alt="Aerospace structural forgings" style="width:100%; height:100%; object-fit:cover; transition:transform 0.4s ease;" class="product-img-modern" />
          </div>
          <div style="padding: 2rem; flex-grow:1; display:flex; flex-direction:column;">
            <h3 style="font-family:'Plus Jakarta Sans',sans-serif; margin-bottom:0.75rem;">Aerospace & Precision Forgings</h3>
            <p style="font-size:0.9rem; line-height:1.6; color:var(--ink-soft); margin-bottom:1.5rem;">
              Ultralow impurity primary aluminium feedstock matching high-spec 7000 and 2000 series alloying parameters for aviation fuselage frames and structural components.
            </p>
            <span style="font-size:0.85rem; font-weight:600; color:var(--teal); margin-top:auto;">Primary alloy: A7 (99.7%)</span>
          </div>
        </div>

        <!-- Electrical Grid -->
        <div class="app-item" style="background:var(--silver-soft); border:1px solid var(--border); border-radius:var(--radius-lg); overflow:hidden; display:flex; flex-direction:column;">
          <div style="aspect-ratio:16/9; overflow:hidden;">
            <img src="/images/applications/4.7-aluminium-power-cable-conductors-rail-transit-components.webp" alt="Electrical Conductors and Grid" style="width:100%; height:100%; object-fit:cover; transition:transform 0.4s ease;" class="product-img-modern" />
          </div>
          <div style="padding: 2rem; flex-grow:1; display:flex; flex-direction:column;">
            <h3 style="font-family:'Plus Jakarta Sans',sans-serif; margin-bottom:0.75rem;">Electrical Grid & Power Transmission</h3>
            <p style="font-size:0.9rem; line-height:1.6; color:var(--ink-soft); margin-bottom:1.5rem;">
              Highly conductive A7 Primary ingots optimized for continuous casting and rolling of transmission wire rod, high-voltage overhead cables, and busbars.
            </p>
            <span style="font-size:0.85rem; font-weight:600; color:var(--teal); margin-top:auto;">Primary alloy: A7 (99.7%)</span>
          </div>
        </div>

        <!-- Industrial Machinery -->
        <div class="app-item" style="background:var(--silver-soft); border:1px solid var(--border); border-radius:var(--radius-lg); overflow:hidden; display:flex; flex-direction:column;">
          <div style="aspect-ratio:16/9; overflow:hidden;">
            <img src="/images/applications/4.8-aluminium-cnc-machined-parts-industrial-manufacturing.webp" alt="Industrial Machinery" style="width:100%; height:100%; object-fit:cover; transition:transform 0.4s ease;" class="product-img-modern" />
          </div>
          <div style="padding: 2rem; flex-grow:1; display:flex; flex-direction:column;">
            <h3 style="font-family:'Plus Jakarta Sans',sans-serif; margin-bottom:0.75rem;">Heavy Industrial Machinery</h3>
            <p style="font-size:0.9rem; line-height:1.6; color:var(--ink-soft); margin-bottom:1.5rem;">
              ADC12 casting alloys for manufacturing motor housings, high-stress hydraulic pump brackets, pneumatic valves, and complex robotic joint components.
            </p>
            <span style="font-size:0.85rem; font-weight:600; color:var(--teal); margin-top:auto;">Primary alloy: ADC12</span>
          </div>
        </div>

        <!-- Packaging -->
        <div class="app-item" style="background:var(--silver-soft); border:1px solid var(--border); border-radius:var(--radius-lg); overflow:hidden; display:flex; flex-direction:column;">
          <div style="aspect-ratio:16/9; overflow:hidden;">
            <img src="/images/applications/4.6-aluminium-packaging-cans-foil-beverage-food-industry.webp" alt="Aluminium Packaging" style="width:100%; height:100%; object-fit:cover; transition:transform 0.4s ease;" class="product-img-modern" />
          </div>
          <div style="padding: 2rem; flex-grow:1; display:flex; flex-direction:column;">
            <h3 style="font-family:'Plus Jakarta Sans',sans-serif; margin-bottom:0.75rem;">Food & Pharmaceutical Packaging</h3>
            <p style="font-size:0.9rem; line-height:1.6; color:var(--ink-soft); margin-bottom:1.5rem;">
              Rolling slab feedstock sourced from pure A7 primary melts for food preservation foil, deep-drawn beverage cans, and sterile medical packaging materials.
            </p>
            <span style="font-size:0.85rem; font-weight:600; color:var(--teal); margin-top:auto;">Primary alloy: A7 (99.7%)</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       FINAL CTA
       ============================================================ -->
  <section class="final-cta">
    <div class="container">
      <span class="eyebrow on-dark">Direct B2B Procurement</span>
      <h2>Secure your feedstock supply allocation</h2>
      <p>Whether you require narrowed composition windows, custom heat bundle counts, or trial shipment allocations, speak directly with Noel Murphy.</p>
      <div class="final-cta-actions">
        <a href="/en/contact/" class="btn btn-primary">Request a Quote</a>
        <a href="https://wa.me/353871187806" class="btn btn-secondary">Message Noel on WhatsApp</a>
      </div>
      <p class="final-cta-direct">
        Direct Email: <a href="mailto:noel@techaluminum.com">noel@techaluminum.com</a> · WhatsApp: <a href="https://wa.me/353871187806">Direct Chat</a>
      </p>
    </div>
  </section>
</Layout>

<style>
  .product-img-modern:hover {
    transform: scale(1.03);
  }
</style>
