---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="Aluminium Ingots for Aerospace & Defence | Tech Aluminum" lang="en">
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <div class="container"><ol>
      <li><a href="/en/">Home</a></li>
      <li><a href="/en/industries/">Industries</a></li>
      <li aria-current="page">Aerospace</li>
    </ol></div>
  </nav>

  <section class="product-hero">
    <div class="container">
      <div class="product-hero-grid" style="grid-template-columns:1fr;">
        <div style="max-width:800px;">
          <span class="eyebrow on-dark">Industry Application</span>
          <h1>Aluminium for Aerospace & Defence</h1>
          <p class="product-hero-lead">High-purity primary ingots for aerospace structural alloy production. Full chemical traceability, REACH compliance, and mill test certificates on every shipment.</p>
          <div class="product-hero-ctas">
            <a href="/en/contact/" class="btn btn-primary">Request Specifications</a>
            <a href="/en/products/" class="btn btn-secondary">View All Products</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section style="padding:5rem 0;background:var(--warm-white);">
    <div class="container" style="max-width:820px;">
      <h2>Products for aerospace applications</h2>
      <p>Aerospace and defence applications require the strictest chemical purity, full batch traceability, and documented compliance at every stage of the supply chain. Our primary ingots provide the verified base material your downstream alloy production depends on.</p>
      <ul>
        <li><strong>A7 Primary Aluminium Ingot (EN 576, P1020A)</strong> — 99.7% minimum aluminium purity. The foundation charge material for high-strength aerospace alloy series (2xxx, 6xxx, 7xxx). Full chemical composition certificates with every shipment.</li>
        <li><strong>AL-Si Alloy Ingot (EN 1706)</strong> — Used in precision gravity and investment castings for aircraft engine components and structural brackets requiring tight silicon distribution control.</li>
      </ul>
      <p>We provide REACH compliance documentation, material safety data sheets, and CBAM embedded-emissions data as standard on all European shipments.</p>
      <a href="/en/contact/" class="btn btn-primary" style="margin-top:1.5rem;display:inline-flex;">Request specifications →</a>
    </div>
  </section>

  <section class="final-cta">
    <div class="container">
      <h2>Sourcing aluminium for aerospace production?</h2>
      <p>Noel Murphy handles all European enquiries. Response within 24 hours.</p>
      <div class="final-cta-actions">
        <a href="/en/contact/" class="btn btn-primary">Request a Quote</a>
        <a href="https://wa.me/353871187806" class="btn btn-secondary">WhatsApp</a>
      </div>
    </div>
  </section>
</Layout>
