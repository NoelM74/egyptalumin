                <tr><td>Standard ingot weight</td><td>25 kg ± 0.5 kg</td></tr>
                <tr><td>Bundle weight</td><td>500–1,000 kg (configurable)</td></tr>
                <tr><td>Density</td><td>≈ 2.70 g/cm³</td></tr>
                <tr><td>Melting point</td><td>~660 °C</td></tr>
                <tr><td>Surface condition</td><td>Clean, free from slag and dross</td></tr>
                <tr><td>Marking</td><td>Heat number, grade designation and weight stamped per ingot</td></tr>
                <tr><td>Tonnes per 20ft container</td><td>~20–22 t</td></tr>
                <tr><td>Tonnes per 40ft container</td><td>~24–26 t</td></tr>
              </tbody>
            </table>

