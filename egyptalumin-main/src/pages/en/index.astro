---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Premium Aluminium Ingots from Egypt to Europe | Egypt Alumin" lang="en">
  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="hero" aria-label="Introduction">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-text-block">
          <span class="eyebrow on-dark">Aluminium Ingots · Egypt → Europe</span>
          <h1 class="hero-title">Premium Aluminium Ingots from Egypt to Europe</h1>
          <p class="hero-sub">
            EN-standard compliant. CBAM-ready. Direct European contact.
            Trusted by foundries and manufacturers across Germany, Italy, France and the UK.
          </p>
          <div class="hero-ctas">
            <a href="/en/contact/" class="btn btn-primary">
              Request a Quote
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
            <a href="/en/products/" class="btn btn-secondary">View Our Products</a>
          </div>
          <div class="hero-badges" aria-label="Key credentials">
            <span>ISO 9001 Certified</span>
            <span>REACH Compliant</span>
            <span>CBAM Ready</span>
            <span>50,000+ Tonnes / Year</span>
          </div>
        </div>
        <div class="hero-visual" aria-hidden="true">
          <!-- Premium image frame with dynamic overlay -->
          <div class="hero-img-container">
            <img src="/images/hero/1.1-egypt-alumin-aluminium-ingot-production-facility.webp" alt="Aluminium Factory Production Line" class="hero-img-modern" />
            <div class="hero-overlay-gradient"></div>
            <div class="hero-img-badge">
              <strong>EGYPT ALUMIN FACILITY</strong>
              <span>State-of-the-Art Smelter</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust bar directly under hero -->
  <div class="trust-bar" aria-label="Credentials">
    <div class="container">
      <div class="trust-bar-inner">
        <span><i class="trust-dot"></i> ISO 9001 Quality Management</span>
        <span><i class="trust-dot"></i> REACH Compliant</span>
        <span><i class="trust-dot"></i> CBAM Ready (2026)</span>
        <span><i class="trust-dot"></i> Supplying 30+ Countries</span>
        <span><i class="trust-dot"></i> Established 2020</span>
      </div>
    </div>
  </div>

  <!-- ============================================================
       THE NOEL MURPHY SECTION — Conversion centrepiece
       ============================================================ -->
  <section class="noel-section" id="noel-contact-section" aria-labelledby="noel-heading">
    <div class="container">
      <div class="noel-grid">

        <div class="noel-photo-wrapper" aria-hidden="true">
          <span class="noel-flag">
            <span class="flag-ie" aria-hidden="true"><span></span><span></span><span></span></span>
            Ireland
          </span>
          <img src="/images/branding/brand-noel-murphy-portrait-01.webp" alt="Noel Murphy - Partner, European Operations" class="noel-img-modern" />
          <div class="noel-photo-overlay"></div>
        </div>

        <div class="noel-content">
          <span class="eyebrow">Your Direct European Contact</span>
          <h2 id="noel-heading">Speak directly with our European partner</h2>
          <p class="lead">
            I'm <strong>Noel Murphy</strong>, partner at Egypt Alumin and the European face of our business.
            Based in Ireland, I joined the partnership to bridge Egypt's world-class aluminium production
            with Europe's precision manufacturing standards.
          </p>
          <blockquote>
            When you work with Egypt Alumin, you deal directly with me — an Irish businessman who
            understands European procurement, contract expectations, and what "reliability"
            means to a German, Italian or French buyer. No intermediaries. No language barriers.
            No timezone confusion. Just straightforward, professional service backed by a serious
            production partner in Egypt.
            <cite>— Noel Murphy, Partner — European Operations</cite>
          </blockquote>

          <div class="noel-contacts">
            <a class="noel-contact" href="tel:+353871187806" aria-label="Call Noel Murphy">
              <span class="icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.9.31 1.78.57 2.62a2 2 0 0 1-.45 2.11L8 9.91a16 16 0 0 0 6 6l1.46-1.23a2 2 0 0 1 2.11-.45c.84.26 1.72.45 2.62.57A2 2 0 0 1 22 16.92z"/></svg>
              </span>
              <span><small>Phone (Ireland)</small><strong>+353 87 118 7806</strong></span>
            </a>
            <a class="noel-contact" href="mailto:noel@egyptalumin.com" aria-label="Email Noel Murphy">
              <span class="icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </span>
              <span><small>Email</small><strong>noel@egyptalumin.com</strong></span>
            </a>
            <a class="noel-contact" href="https://wa.me/353871187806" aria-label="WhatsApp Noel Murphy">
              <span class="icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
              </span>
              <span><small>WhatsApp</small><strong>Direct chat</strong></span>
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       PARTNERSHIP PROVENANCE
       ============================================================ -->
  <aside class="provenance" aria-label="Partnership provenance">
    <div class="container">
      <div class="provenance-inner">
        <div class="provenance-line">
          <span>An Egyptian production facility</span>
          <span class="provenance-divider">·</span>
          <span>An Irish European partner</span>
          <span class="provenance-divider">·</span>
          <span>One direct line of accountability</span>
        </div>
        <p>Transparent ownership, transparent supply chain. <a href="/en/about/partnership/">Learn about our partnership structure →</a></p>
      </div>
    </div>
  </aside>

  <!-- ============================================================
       METRICS
       ============================================================ -->
  <section class="metrics-section" aria-label="Key metrics">
    <div class="container">
      <div class="metrics-grid">
        <div class="metric-card">
          <div class="metric-num" data-target="50000">0<span class="unit">t</span></div>
          <div class="metric-label">Current Annual Capacity</div>
        </div>
        <div class="metric-card">
          <div class="metric-num" data-target="100000">0<span class="unit">t</span></div>
          <div class="metric-label">Expansion Underway</div>
        </div>
        <div class="metric-card">
          <div class="metric-num" data-target="500">0<span class="unit">+</span></div>
          <div class="metric-label">Partner Companies</div>
        </div>
        <div class="metric-card">
          <div class="metric-num" data-target="30">0<span class="unit">+</span></div>
          <div class="metric-label">Export Countries</div>
        </div>
        <div class="metric-card">
          <div class="metric-num" data-target="50">0<span class="unit">+</span></div>
          <div class="metric-label">Product Specifications</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PRODUCTS
       ============================================================ -->
  <section class="products-section" id="products" aria-labelledby="products-heading">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Core Product Lines</span>
        <h2 id="products-heading">Three core product lines, engineered for European industry</h2>
        <p>All ingots manufactured to EN standards with full chemical composition documentation and CBAM-ready emissions data.</p>
      </div>

      <div class="product-grid">

        <article class="product-card-modern">
          <div class="product-img-wrapper">
            <img src="/images/products/2.2-a7-aluminium-ingot-bundle-steel-strapped-palletised.webp" alt="A7 Ingot" class="product-img-asset" />
            <div class="product-img-overlay">
              <span class="product-img-label">A7 Primary Aluminium Ingot · 25 kg</span>
            </div>
          </div>
          <div class="product-body">
            <span class="product-tag">EN 576 · GB/T 1196</span>
            <h3 class="product-title">A7 Primary Aluminium Ingot</h3>
            <div class="product-specs">
              <span>Al ≥ 99.7%</span>
              <span>25 kg ingot</span>
              <span>P1020A grade</span>
            </div>
            <p class="product-desc">The foundational raw material for aluminium processing — high purity, minimal impurities, ready for remelting and further fabrication.</p>
            <a href="/en/products/a7-primary-aluminium-ingot/" class="product-link">
              View full specifications
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>

        <article class="product-card-modern">
          <div class="product-img-wrapper">
            <img src="/images/products/2.3-adc12-die-casting-aluminium-alloy-ingot-en-ac-46000.webp" alt="ADC12 Alloy" class="product-img-asset" />
            <div class="product-img-overlay">
              <span class="product-img-label">ADC12 Die-Casting Ingot · 20 kg</span>
            </div>
          </div>
          <div class="product-body">
            <span class="product-tag">EN AC-46000 · JIS H 5302</span>
            <h3 class="product-title">ADC12 Die-Casting Alloy</h3>
            <div class="product-specs">
              <span>Si 9.6–12%</span>
              <span>20 kg ingot</span>
              <span>AlSi9Cu3(Fe)</span>
            </div>
            <p class="product-desc">The industry-standard die-casting alloy for thin-walled, complex castings at scale — stable mechanical properties and excellent castability.</p>
            <a href="/en/products/adc12-die-casting-alloy/" class="product-link">
              View full specifications
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>

        <article class="product-card-modern">
          <div class="product-img-wrapper">
            <img src="/images/products/2.4-aluminium-silicon-alloy-ingot-en-1706-precision-casting.webp" alt="AL-Si Alloy" class="product-img-asset" />
            <div class="product-img-overlay">
              <span class="product-img-label">AL-Si Alloy Ingot · 20 kg</span>
            </div>
          </div>
          <div class="product-body">
            <span class="product-tag">EN 1706 · GB/T 1173</span>
            <h3 class="product-title">AL-Si Aluminium-Silicon Alloy</h3>
            <div class="product-specs">
              <span>Al ≥ 99.7% + Si</span>
              <span>20 kg ingot</span>
              <span>AC-4xxxx series</span>
            </div>
            <p class="product-desc">Precision-formulated aluminium-silicon alloy with superior fluidity — engineered for automotive engine components and precision die-casting.</p>
            <a href="/en/products/aluminium-silicon-alloy-ingot/" class="product-link">
              View full specifications
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- ============================================================
       WHY EGYPT ALUMIN — 4 pillars
       ============================================================ -->
  <section class="why" aria-labelledby="why-heading">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Why Egypt Alumin</span>
        <h2 id="why-heading">Four reasons European buyers choose us</h2>
      </div>

      <div class="pillar-grid">

        <div class="pillar">
          <div class="pillar-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21V8l9-5 9 5v13"/><path d="M9 21V12h6v9"/></svg>
          </div>
          <h3>European standards, Egyptian production</h3>
          <p>Manufactured to <strong>EN 1706 and EN 576</strong> specifications at our 50,000 m² facility. European-grade quality at competitive Egyptian production costs.</p>
        </div>

        <div class="pillar">
          <div class="pillar-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10"/><path d="M12 2v10l7 3"/></svg>
          </div>
          <h3>CBAM-ready from day one</h3>
          <p>The EU's Carbon Border Adjustment Mechanism is live. We provide <strong>verified embedded-emissions data</strong> and full CBAM reporting support — your compliance, effortless.</p>
        </div>

        <div class="pillar">
          <div class="pillar-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3>Direct Irish contact — no middlemen</h3>
          <p>Deal directly with Noel Murphy, our Irish partner. European business culture, native English, your timezone. One call to <strong>+353 87 118 7806</strong>.</p>
        </div>

        <div class="pillar">
          <div class="pillar-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h20"/><path d="M5 20V8l7-4 7 4v12"/><path d="M9 14h6"/><path d="M9 10h6"/></svg>
          </div>
          <h3>Mediterranean logistics — fast & reliable</h3>
          <p>Direct shipping to <strong>Rotterdam, Hamburg, Antwerp, Genoa, Barcelona and Felixstowe</strong>. Shorter transit than India or the Gulf. Full export documentation included.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       INDUSTRIES
       ============================================================ -->
  <section class="industries" aria-labelledby="industries-heading">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow on-dark">Application Industries</span>
        <h2 id="industries-heading">Trusted across seven key industries</h2>
        <p>From EV battery housings to aircraft frames, our ingots feed European manufacturing's most demanding applications.</p>
      </div>

      <div class="industry-grid">

        <a href="/en/industries/automotive/" class="industry">
          <span class="industry-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 17h14M5 17a2 2 0 0 1-2-2v-2l2-5a2 2 0 0 1 1.8-1.4L10 6h4l3.2.6A2 2 0 0 1 19 8l2 5v2a2 2 0 0 1-2 2"/><circle cx="7.5" cy="17" r="2"/><circle cx="16.5" cy="17" r="2"/></svg>
          </span>
          <span class="industry-name">Automotive</span>
          <span class="industry-desc">Engine blocks, wheel hubs, EV battery housings, body structural components.</span>
          <span class="arrow">Explore →</span>
        </a>

        <a href="/en/industries/aerospace/" class="industry">
          <span class="industry-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>
          </span>
          <span class="industry-name">Aerospace</span>
          <span class="industry-desc">Aircraft skins, structural frames, high-strength alloy applications.</span>
          <span class="arrow">Explore →</span>
        </a>

        <a href="/en/industries/construction/" class="industry">
          <span class="industry-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21V8l9-5 9 5v13"/><rect x="9" y="14" width="6" height="7"/></svg>
          </span>
          <span class="industry-name">Construction</span>
          <span class="industry-desc">Curtain wall profiles, window/door frames, decorative panels.</span>
          <span class="arrow">Explore →</span>
        </a>

        <a href="/en/industries/electronics/" class="industry">
          <span class="industry-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M9 1v3M15 1v3M9 20v3M15 20v3M20 9h3M20 14h3M1 9h3M1 14h3"/></svg>
          </span>
          <span class="industry-name">Electronics</span>
          <span class="industry-desc">Heat sinks, device housings, conductive connectors.</span>
          <span class="arrow">Explore →</span>
        </a>

        <a href="/en/industries/packaging/" class="industry">
          <span class="industry-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V12"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          </span>
          <span class="industry-name">Packaging</span>
          <span class="industry-desc">Aluminium cans, food packaging foil, pharmaceutical foil.</span>
          <span class="arrow">Explore →</span>
        </a>

        <a href="/en/industries/power-transportation/" class="industry">
          <span class="industry-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
