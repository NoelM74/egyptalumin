          <span class="industry-name">Mechanical Mfg.</span>
          <span class="industry-desc">Industrial equipment parts, moulds, automation components.</span>
          <span class="arrow">Explore →</span>
        </a>

      </div>
    </div>
  </section>

  <!-- ============================================================
       CBAM CALLOUT
       ============================================================ -->
  <section class="cbam" aria-labelledby="cbam-heading">
    <div class="container">
      <div class="cbam-inner">
        <div>
          <span class="eyebrow on-dark">EU Compliance · 2026</span>
          <h2 id="cbam-heading">Navigating CBAM? We've got you covered.</h2>
          <p>
            The EU Carbon Border Adjustment Mechanism entered its definitive phase on
            <strong>1 January 2026</strong>. As your aluminium supplier, we provide all the
            verified emissions data and documentation your CBAM declaration requires — built into every shipment.
          </p>
          <a href="/en/cbam-guide/" class="btn btn-primary">
            Read our CBAM Guide
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>

        <div class="cbam-stats" aria-label="CBAM key facts">
          <div class="cbam-stat">
            <strong>12,000+</strong>
            <span>EU operators registered as CBAM authorised declarants</span>
          </div>
          <div class="cbam-stat">
            <strong>50 t</strong>
            <span>Annual aluminium threshold for full CBAM registration</span>
          </div>
          <div class="cbam-stat">
            <strong>31 May 2027</strong>
            <span>First CBAM certificate surrender deadline (for 2026 imports)</span>
          </div>
          <div class="cbam-stat">
            <strong>Verified</strong>
            <span>Third-party-verified embedded-emissions data provided</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FINAL CTA
       ============================================================ -->
  <section class="final-cta" aria-labelledby="cta-heading">
    <div class="container">
      <span class="eyebrow on-dark">Ready when you are</span>
      <h2 id="cta-heading">Let's discuss your aluminium requirements</h2>
      <p>Tell us the alloy grade, the tonnage and the delivery port — we'll respond within 24 hours with pricing, lead time and full documentation.</p>
      <div class="final-cta-actions">
        <a href="/en/contact/" class="btn btn-primary">Request a Quote</a>
        <a href="https://wa.me/353871187806" class="btn btn-secondary">Chat on WhatsApp</a>
      </div>
      <p class="final-cta-direct">
        Or contact Noel directly:
        <a href="tel:+353871187806">+353 87 118 7806</a> ·
        <a href="mailto:noel@egyptalumin.com">noel@egyptalumin.com</a>
      </p>
    </div>
  </section>
</Layout>

<script>
  // Simple intersection observer to animate the metric numbers nicely!
  const metricsSection = document.querySelector('.metrics-section');
  const metricNums = document.querySelectorAll('.metric-num');

  if (metricsSection && metricNums.length > 0) {
    const animateCounters = () => {
      metricNums.forEach(num => {
        const target = parseInt(num.getAttribute('data-target') || '0', 10);
        const unit = num.querySelector('.unit')?.outerHTML || '';
        let start = 0;
        const duration = 1200; // ms
        const stepTime = Math.abs(Math.floor(duration / target)) || 10;
        
        // Speed scaling for large numbers like 50,000 / 100,000
        const increment = target > 1000 ? Math.ceil(target / 100) : 1;

        const timer = setInterval(() => {
          start += increment;
          if (start >= target) {
            start = target;
            clearInterval(timer);
          }
          // Formatting with commas for large numbers
          const formatted = start.toLocaleString();
          num.innerHTML = `${formatted}${unit}`;
        }, stepTime);
      });
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          animateCounters();
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    observer.observe(metricsSection);
  }
</script>

