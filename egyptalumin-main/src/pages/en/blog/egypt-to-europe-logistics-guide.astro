                    <span>8 min read</span>
                  </div>
                </a>
              </li>
              <li>
                <a href="/en/blog/egypt-aluminium-industry-overview/" class="mini-article-card">
                  <div class="mini-article-thumb">IND</div>
                  <div class="mini-article-info">
                    <strong>Egypt's Smelting Capacities</strong>
                    <span>5 min read</span>
                  </div>
                </a>
              </li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </article>
</Layout>
