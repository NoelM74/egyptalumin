        "@type": "Organization",
        "name": "Egypt Alumin",
        "logo": {
          "@type": "ImageObject",
          "url": "https://egyptalumin.com/assets/logo.png"
        }
      }
    }
  ]
};
---

<Layout 
  title="Aluminium-Massel-Qualitäten-Leitfaden | Egypt Alumin"
  description="Technische Analyse von Primäraluminium-Spezifikationen (EN 576, P1020A), chemischen Reinheitsgrenzen, Verunreinigungen und optimalen Umschmelzpraktiken."
  lang="de"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <nav class="breadcrumb" aria-label="Breadcrumb">
    <div class="container">
      <ol>
        {breadcrumbs.map((b, i) => (
          i === breadcrumbs.length - 1 ? (
