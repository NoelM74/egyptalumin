      "datePublished": "2026-05-25T08:00:00+08:00",
      "dateModified": "2026-05-25T08:00:00+08:00",
      "author": {
        "@type": "Person",
        "name": "Noel Murphy",
        "jobTitle": "Partner, Europäische Operationen",
        "worksFor": {
          "@type": "Organization",
          "name": "Egypt Alumin"
        }
