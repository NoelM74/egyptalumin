            <li><a href={b.url}>{b.name}</a></li>
          )
        ))}
      </ol>
    </div>
  </nav>

  <article class="article-container">
    <header class="article-header">
      <div class="container">
        <div class="article-header-meta">
          <span class="article-badge">Technisch</span>
          <span>25. Mai 2026</span>
          <span>•</span>
          <span>6 Min. Lesezeit</span>
        </div>
