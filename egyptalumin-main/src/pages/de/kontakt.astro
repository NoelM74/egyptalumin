---
import Layout from '../../layouts/Layout.astro';

// RFQ-Formular: kostenlosen Access-Key unter https://web3forms.com holen
// (Zielpostfach contact@techaluminum.com) und unten einsetzen. Solange kein
// Key gesetzt ist, öffnet das Formular automatisch die E-Mail-App des Besuchers.
const WEB3FORMS_KEY = '2b6f383a-1087-4cde-8534-d0628fcc305b';
const RFQ_TO = 'contact@techaluminum.com';
---

<Layout 
  title="Kontaktieren Sie unseren B2B-Vertrieb & Technik | Tech Aluminum" 
  description="Fordern Sie ein Angebot oder ein Materialmuster unserer Primäraluminiumbarren, ADC12- oder AL-Si-Siliziumlegierungen an. Direkter Kontakt mit Noel Murphy."
  lang="de"
>
  <nav class="breadcrumb" aria-label="Brotkrumen-Navigation">
    <div class="container">
      <ol>
        <li><a href="/de/">Startseite</a></li>
        <li aria-current="page">Kontakt</li>
      </ol>
    </div>
  </nav>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="product-hero" style="padding: 4rem 0 3rem 0;">
    <div class="container">
      <div style="text-align: center; max-width: 800px; margin: 0 auto;">
        <span class="eyebrow on-dark">Schnelle B2B-Rückmeldung innerhalb von 24h</span>
        <h1 style="font-size: 3rem; margin-bottom: 1rem;">B2B-Vertrieb & technischer Service</h1>
        <p class="product-hero-lead" style="font-size: 1.15rem; color: rgba(255,255,255,0.85);">
          Fordern Sie standardisierte Preistabellen, engere Zusammensetzungsfenster oder ein Probelieferungskonzept 
          für Ihre Schmelzversuche direkt bei Noel Murphy an.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CONTACT GRID
       ============================================================ -->
  <section style="background: var(--white); padding: 5rem 0;">
    <div class="container">
      <div class="cbam-inner" style="grid-template-columns: 1.2fr 0.8fr; gap: 4rem; align-items: start;">
        
        <!-- Contact Form Card -->
        <div style="background: var(--silver-soft); border: 1px solid var(--border); padding: 3rem; border-radius: var(--radius-lg); box-shadow: var(--shadow-sm);">
          <h2 style="font-size: 1.8rem; margin-bottom: 0.5rem; font-family:'Plus Jakarta Sans',sans-serif;">Angebot anfordern (RFQ)</h2>
          <p style="color:var(--ink-soft); font-size:0.95rem; margin-bottom: 2rem;">Füllen Sie bitte das folgende Formular aus. Noel Murphy oder unsere technische Abteilung meldet sich innerhalb von 24 Stunden bei Ihnen.</p>
          
          <form id="rfq-form" class="contact-form" style="display:flex; flex-direction:column; gap:1.5rem;">
            <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
            <input type="hidden" name="subject" value="Neue RFQ — Tech Aluminum Website" />
            <input type="hidden" name="from_name" value="Tech Aluminum Website" />
            <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" aria-hidden="true" style="display:none" />
            <div class="form-row">
              <div>
                <label style="display:block; font-size:0.85rem; font-weight:600; margin-bottom:0.5rem; color:var(--navy);">Vor- & Nachname *</label>
                <input type="text" name="Name" required placeholder="Max Mustermann" style="width:100%; padding:0.75rem; border:1px solid var(--border); border-radius:6px; font-family:inherit;" />
              </div>
              <div>
                <label style="display:block; font-size:0.85rem; font-weight:600; margin-bottom:0.5rem; color:var(--navy);">Firmenname *</label>
                <input type="text" name="Firma" required placeholder="Gießerei GmbH" style="width:100%; padding:0.75rem; border:1px solid var(--border); border-radius:6px; font-family:inherit;" />
              </div>
            </div>

            <div class="form-row">
              <div>
                <label style="display:block; font-size:0.85rem; font-weight:600; margin-bottom:0.5rem; color:var(--navy);">Geschäftliche E-Mail *</label>
                <input type="email" name="E-Mail" required placeholder="mustermann@firma.de" style="width:100%; padding:0.75rem; border:1px solid var(--border); border-radius:6px; font-family:inherit;" />
              </div>
              <div>
                <label style="display:block; font-size:0.85rem; font-weight:600; margin-bottom:0.5rem; color:var(--navy);">WhatsApp / Telefon</label>
                <input type="text" name="WhatsApp oder Telefon" placeholder="+49 170 1234567" style="width:100%; padding:0.75rem; border:1px solid var(--border); border-radius:6px; font-family:inherit;" />
              </div>
            </div>

            <div class="form-row">
              <div>
                <label style="display:block; font-size:0.85rem; font-weight:600; margin-bottom:0.5rem; color:var(--navy);">Produktkategorie</label>
                <select name="Produktkategorie" style="width:100%; padding:0.75rem; border:1px solid var(--border); border-radius:6px; font-family:inherit; background:white;">
                  <option>Primär-Aluminiummassel (A7 / Al99.7)</option>
                  <option>Druckgusslegierung (ADC12 / EN AC-46000)</option>
                  <option>Aluminium-Silizium-Legierung (AlSi7Mg / AlSi11 / Andere)</option>
                  <option>Andere Spezifikation / Kundenspezifische Schmelze</option>
                </select>
              </div>
              <div>
                <label style="display:block; font-size:0.85rem; font-weight:600; margin-bottom:0.5rem; color:var(--navy);">Geschätzter Monatsbedarf (Tonnen)</label>
                <input type="text" name="Monatsbedarf" placeholder="z. B. 50 Tonnen" style="width:100%; padding:0.75rem; border:1px solid var(--border); border-radius:6px; font-family:inherit;" />
              </div>
            </div>

            <div>
              <label style="display:block; font-size:0.85rem; font-weight:600; margin-bottom:0.5rem; color:var(--navy);">Spezifische Anforderungen / Nachricht</label>
              <textarea name="Nachricht" placeholder="Bitte beschreiben Sie gewünschte Toleranzfenster, Verpackungsbündelungen oder Wünsche für Testlieferungen..." style="width:100%; padding:0.75rem; border:1px solid var(--border); border-radius:6px; font-family:inherit; min-height:120px; resize:vertical;"></textarea>
            </div>

            <button type="submit" class="btn btn-primary" style="width:fit-content; cursor:pointer; font-size:1rem; padding: 0.85rem 2rem;">RFQ absenden</button>
            <div id="rfq-status" role="status" aria-live="polite" style="font-size:0.9rem; font-weight:600;"></div>
          </form>
        </div>

        <!-- Noel Murphy Profile Card & Quick Info -->
        <div style="display:flex; flex-direction:column; gap:2rem;">
          
          <div style="background:var(--silver-soft); border:1px solid var(--border); padding:2rem; border-radius:var(--radius-lg); text-align:center;">
            <div style="width:110px; height:110px; border-radius:50%; overflow:hidden; margin:0 auto 1.25rem auto; box-shadow:var(--shadow-md);">
              <img src="/images/branding/brand-noel-murphy-portrait-01.webp" alt="Noel Murphy" style="width:100%; height:100%; object-fit:cover;" />
            </div>
            <h3 style="font-family:'Plus Jakarta Sans',sans-serif; margin-bottom:0.25rem;">Noel Murphy</h3>
            <span style="color:var(--teal); font-weight:600; font-size:0.85rem; text-transform:uppercase; tracking:0.05em; display:block; margin-bottom:1rem;">B2B-Vertriebspartner Europa</span>
            
            <hr style="border:0; border-top:1px solid var(--border); margin-bottom:1.25rem;" />
            
            <ul style="list-style:none; padding:0; display:flex; flex-direction:column; gap:0.75rem; font-size:0.9rem; text-align:left;">
              <li style="display:flex; gap:0.5rem;">
                <span>📞</span>
                <a href="https://wa.me/353871187806" style="color:var(--navy); font-weight:600;">WhatsApp</a>
              </li>
              <li style="display:flex; gap:0.5rem;">
                <span>✉️</span>
                <a href="mailto:noel@techaluminum.com" style="color:var(--navy); font-weight:600;">noel@techaluminum.com</a>
              </li>
              <li style="display:flex; gap:0.5rem;">
                <span>💬</span>
                <a href="https://wa.me/353871187806" target="_blank" style="color:var(--teal); font-weight:600;">Direkter WhatsApp-Chat</a>
              </li>
            </ul>
          </div>

          <div style="background:var(--navy); color:white; padding:2rem; border-radius:var(--radius-lg);">
            <h3 style="font-family:'Plus Jakarta Sans',sans-serif; margin-bottom:1rem; font-size:1.15rem; color:var(--amber);">Compliance-Richtlinien:</h3>
            <ul style="list-style:none; padding:0; display:flex; flex-direction:column; gap:0.8rem; font-size:0.85rem; color:rgba(255,255,255,0.85);">
              <li>✓ Vollständige REACH-Registrierungsdaten verfügbar</li>
              <li>✓ Quartalsweise CBAM-Emissionsberichte vorhanden</li>
              <li>✓ ISO 9001:2015-zertifizierte Produktion im Werk</li>
              <li>✓ Abnahmeprüfzeugnisse nach EN 10204 3.1</li>
            </ul>
          </div>

        </div>

      </div>
    </div>
  </section>

  <script define:vars={{ RFQ_TO }}>
    const form = document.getElementById('rfq-form');
    const statusEl = document.getElementById('rfq-status');
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const data = new FormData(form);
        if (data.get('botcheck')) return;
        const key = data.get('access_key');
        statusEl.style.color = 'var(--ink-soft)';
        statusEl.textContent = 'Wird gesendet…';
        if (key && key !== '2b6f383a-1087-4cde-8534-d0628fcc305b') {
          try {
            const res = await fetch('https://api.web3forms.com/submit', {
              method: 'POST', headers: { Accept: 'application/json' }, body: data
            });
            const out = await res.json();
            if (out.success) {
              form.reset();
              statusEl.style.color = 'var(--teal)';
              statusEl.textContent = 'Vielen Dank — Ihre Anfrage wurde gesendet. Noel meldet sich innerhalb eines Werktages.';
              return;
            }
          } catch (err) { /* Fallback: mailto */ }
        }
        const skip = ['access_key', 'subject', 'from_name', 'botcheck'];
        const lines = [];
        for (const [k, v] of data.entries()) { if (!skip.includes(k) && v) lines.push(k + ': ' + v); }
        window.location.href = 'mailto:' + RFQ_TO + '?subject=' + encodeURIComponent('Neue RFQ — Tech Aluminum Website') + '&body=' + encodeURIComponent(lines.join('\n'));
        statusEl.style.color = 'var(--ink-soft)';
        statusEl.textContent = 'Ihre E-Mail-App wird geöffnet, um die Anfrage an ' + RFQ_TO + ' zu senden…';
      });
    }
  </script>
</Layout>
