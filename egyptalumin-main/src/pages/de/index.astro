  <!-- Interactive Counters Script -->
  <script is:inline>
    const counters = document.querySelectorAll('.metric-num');
    const speed = 100; // The lower the faster

    const startCounters = () => {
      counters.forEach(counter => {
        const valAttr = counter.getAttribute('data-val');
        if (!valAttr) return;
        const target = +valAttr;
        let count = 0;
        const inc = Math.max(1, Math.floor(target / speed));
        
        const updateCount = () => {
          count += inc;
          if (count < target) {
            // Append format nicely with thousands separators if needed
            let formatted = count.toLocaleString('de-DE');
            if (valAttr === '500') {
              counter.innerHTML = formatted + '<span class="unit">+</span>';
            } else if (valAttr === '30' || valAttr === '50') {
              counter.innerHTML = formatted + '<span class="unit">+</span>';
            } else {
              counter.innerHTML = formatted + '<span class="unit">t</span>';
            }
            setTimeout(updateCount, 15);
          } else {
            let formatted = target.toLocaleString('de-DE');
            if (valAttr === '500') {
              counter.innerHTML = formatted + '<span class="unit">+</span>';
            } else if (valAttr === '30' || valAttr === '50') {
              counter.innerHTML = formatted + '<span class="unit">+</span>';
            } else {
              counter.innerHTML = formatted + '<span class="unit">t</span>';
            }
          }
        };
        updateCount();
      });
    };

    // Trigger animation when visible
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          startCounters();
          observer.disconnect();
        }
      });
    }, { threshold: 0.1 });

    const metricsSection = document.querySelector('.metrics');
    if (metricsSection) {
      observer.observe(metricsSection);
    } else {
      startCounters();
    }
  </script>
