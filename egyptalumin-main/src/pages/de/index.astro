---
import Layout from '../../layouts/Layout.astro';
---

<Layout 
  title="Premium Aluminium-Masseln aus Ägypten für Europa | Tech Aluminum" 
  description="EN-konforme A7-, ADC12- und AL-Si-Aluminiummasseln. CBAM-bereit. Direkter europäischer Ansprechpartner über den irischen Partner Noel Murphy. Vertraut von Gießereien in Deutschland, Italien, Frankreich und Großbritannien." 
  lang="de"
>
  <!-- Schema: Organization (German) -->
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Tech Aluminum",
    "alternateName": "Tech Aluminum (Taike Technology)",
    "url": "https://egyptalumin.com/de/",
    "logo": "https://egyptalumin.com/logo.png",
    "description": "Hersteller von Premium-Aluminiummasseln: A7 (P1020A), ADC12 (EN AC-46000) und AL-Si-Legierungen für den europäischen Markt. ISO 9001 zertifiziert. CBAM-bereit. REACH-konform.",
    "foundingDate": "2020",
    "numberOfEmployees": "200+",
    "areaServed": ["DE","IT","FR","GB","NL","BE","ES","PL","CZ","IE","AT","CH"],
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "EG",
      "addressLocality": "Egypt"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "sales",
      "telephone": "+353-87-118-7806",
      "email": "noel@techaluminum.com",
      "availableLanguage": ["German","English","French","Italian"],
      "areaServed": "EU"
    }
  }
  </script>

  <!-- Schema: Person (Noel Murphy) -->
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Noel Murphy",
    "jobTitle": "Partner — Europageschäft",
    "telephone": "+353-87-118-7806",
    "email": "noel@techaluminum.com",
    "nationality": "IE",
    "worksFor": { "@type": "Organization", "name": "Tech Aluminum" },
    "image": "https://egyptalumin.com/images/branding/brand-noel-murphy-portrait-01.webp"
  }
  </script>

  <!-- Schema: WebSite -->
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Tech Aluminum",
    "url": "https://egyptalumin.com/de/",
    "inLanguage": ["de","en"]
  }
  </script>

  <!-- ============================================================
       HERO SECTION
       ============================================================ -->
  <section class="hero" aria-label="Einleitung">
    <div class="container">
      <div class="hero-grid">
        <div>
          <span class="eyebrow on-dark">Aluminium-Masseln · Ägypten → Europa</span>
          <h1 class="main-h1">Premium Aluminium-Masseln aus Ägypten für Europa</h1>
          <p class="hero-sub">
            EN-konform. CBAM-bereit. Direkter europäischer Ansprechpartner über den irischen Partner Noel Murphy.
            Vertraut von Gießereien und Herstellern in Deutschland, Italien, Frankreich und Großbritannien.
          </p>
          <div class="hero-ctas">
            <a href="/de/kontakt/" class="btn btn-primary">
              Angebot anfordern
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
            <a href="/de/produkte/" class="btn btn-secondary">Produkte ansehen</a>
          </div>
          <div class="hero-badges" aria-label="Zentrale Qualifikationen">
            <span><i class="badge-dot"></i> ISO 9001 zertifiziert</span>
            <span><i class="badge-dot"></i> REACH-konform</span>
            <span><i class="badge-dot"></i> CBAM-bereit</span>
            <span><i class="badge-dot"></i> 50.000+ Tonnen / Jahr</span>
          </div>
        </div>
        <div class="hero-visual" aria-hidden="true">
          <div class="hero-img-container">
            <img src="/images/hero/1.1-egypt-alumin-aluminium-ingot-production-facility.webp" alt="Tech Aluminum Produktionslinie" class="hero-img-blend" />
            <div class="hero-blend-overlay"></div>
            <div class="hero-caption">
              <strong>Ägyptische Produktion</strong>
              <span>50.000 m² modernes Gusswerk</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       TRUST BAR
       ============================================================ -->
  <div class="trust-bar" aria-label="Qualifikationen">
    <div class="container">
      <div class="trust-bar-inner">
        <span><i class="trust-dot"></i> ISO 9001 Qualitätsmanagement</span>
        <span><i class="trust-dot"></i> REACH-konform</span>
        <span><i class="trust-dot"></i> CBAM-bereit (2026)</span>
        <span><i class="trust-dot"></i> Lieferung in 30+ Länder</span>
        <span><i class="trust-dot"></i> Gegründet 2020</span>
      </div>
    </div>
  </div>

  <!-- ============================================================
       NOEL MURPHY SECTION
       ============================================================ -->
  <!-- ============================================================
       METRICS (Interactive Counters)
       ============================================================ -->
  <section class="metrics" aria-label="Kennzahlen">
    <div class="container">
      <div class="metrics-grid">
        <div class="metric">
          <div class="metric-num" data-val="50000">50.000<span class="unit">t</span></div>
          <div class="metric-label">Aktuelle Jahreskapazität</div>
        </div>
        <div class="metric">
          <div class="metric-num" data-val="100000">100.000<span class="unit">t</span></div>
          <div class="metric-label">Erweiterung im Aufbau</div>
        </div>
        <div class="metric">
          <div class="metric-num" data-val="500">500<span class="unit">+</span></div>
          <div class="metric-label">Partnerunternehmen</div>
        </div>
        <div class="metric">
          <div class="metric-num" data-val="30">30<span class="unit">+</span></div>
          <div class="metric-label">Exportländer</div>
        </div>
        <div class="metric">
          <div class="metric-num" data-val="50">50<span class="unit">+</span></div>
          <div class="metric-label">Produktspezifikationen</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PRODUCTS SECTION
       ============================================================ -->
  <section class="products" id="products" aria-labelledby="products-heading">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Kern-Produktlinien</span>
        <h2 id="products-heading">Drei Kern-Produktlinien für die europäische Industrie</h2>
        <p>Alle Masseln werden nach EN-Normen gefertigt — mit vollständiger Dokumentation der chemischen Zusammensetzung und CBAM-fähigen Emissionsdaten.</p>
      </div>

      <div class="product-grid">

        <!-- Product 1 -->
        <article class="product-card">
          <div class="product-img-frame">
            <img src="/images/products/2.2-a7-aluminium-ingot-bundle-steel-strapped-palletised.webp" alt="A7 Ingot" class="product-img-asset" />
            <div class="product-img-overlay-label">
              <span>A7 / P1020A Massel · 25 kg</span>
            </div>
          </div>
          <div class="product-body">
            <span class="product-tag">EN 576 · GB/T 1196</span>
            <h3 class="product-title">A7 Primär-Aluminiummassel</h3>
            <div class="product-specs">
              <span>Al ≥ 99,7 %</span>
              <span>25 kg Massel</span>
              <span>P1020A-Qualität</span>
            </div>
            <p class="product-desc">Der Grundwerkstoff für die gesamte Aluminiumverarbeitung — hohe Reinheit, geringste Verunreinigungen, bereit für das Umschmelzen und die Weiterverarbeitung.</p>
            <a href="/de/produkte/a7-primaer-aluminiummassel/" class="product-link">Vollständige Spezifikationen ansehen
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>

        <!-- Product 2 -->
        <article class="product-card">
          <div class="product-img-frame">
            <img src="/images/products/2.3-adc12-die-casting-aluminium-alloy-ingot-en-ac-46000.webp" alt="ADC12 Ingot" class="product-img-asset" />
            <div class="product-img-overlay-label">
              <span>ADC12 Druckguss-Massel · 20 kg</span>
            </div>
          </div>
          <div class="product-body">
            <span class="product-tag">EN AC-46000 · JIS H 5302</span>
            <h3 class="product-title">ADC12 Druckguss-Legierung</h3>
            <div class="product-specs">
              <span>Si 9,6–12 %</span>
              <span>20 kg Massel</span>
              <span>AlSi9Cu3(Fe)</span>
            </div>
            <p class="product-desc">Die Industriestandard-Druckgusslegierung für dünnwandige, komplexe Bauteile in der Serienfertigung — stabile mechanische Eigenschaften und hervorragende Gießbarkeit.</p>
            <a href="/de/produkte/adc12-druckguss-legierung/" class="product-link">Vollständige Spezifikationen ansehen
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>

        <!-- Product 3 -->
        <article class="product-card">
          <div class="product-img-frame">
            <img src="/images/products/2.4-aluminium-silicon-alloy-ingot-en-1706-precision-casting.webp" alt="Al-Si Ingot" class="product-img-asset" />
            <div class="product-img-overlay-label">
              <span>AL-Si Legierungs-Massel · 20 kg</span>
            </div>
          </div>
          <div class="product-body">
            <span class="product-tag">EN 1706 · GB/T 1173</span>
            <h3 class="product-title">AL-Si Aluminium-Silizium-Legierung</h3>
            <div class="product-specs">
              <span>Al ≥ 99,7 % + Si</span>
              <span>20 kg Massel</span>
              <span>AC-4xxxx Reihe</span>
            </div>
            <p class="product-desc">Präzise eingestellte Aluminium-Silizium-Legierung mit hervorragenden Fließeigenschaften — entwickelt für Automotive-Motorenteile und Präzisions-Druckguss.</p>
            <a href="/de/produkte/aluminium-silizium-legierung/" class="product-link">Vollständige Spezifikationen ansehen
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- ============================================================
       WHY TECH ALUMINUM (Pillars)
       ============================================================ -->
  <section class="why" aria-labelledby="why-heading">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Warum Tech Aluminum</span>
        <h2 id="why-heading">Vier Gründe, warum europäische Einkäufer auf uns setzen</h2>
      </div>

      <div class="pillar-grid">

        <div class="pillar">
          <div class="pillar-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21V8l9-5 9 5v13"/><path d="M9 21V12h6v9"/></svg>
          </div>
          <h3>Europäische Normen, ägyptische Produktion</h3>
          <p>Gefertigt nach <strong>EN 1706 und EN 576</strong> in unserem 50.000 m² großen Werk. Europäische Qualität zu wettbewerbsfähigen ägyptischen Produktionskosten.</p>
        </div>

        <div class="pillar">
          <div class="pillar-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10"/><path d="M12 2v10l7 3"/></svg>
          </div>
          <h3>CBAM-bereit ab Tag eins</h3>
          <p>Der EU-Grenzausgleichsmechanismus (CBAM) ist aktiv. Wir liefern <strong>geprüfte Emissionsdaten</strong> und vollständige CBAM-Berichtsunterstützung — Ihre Compliance, ohne Aufwand.</p>
        </div>

        <div class="pillar">
          <div class="pillar-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3>Direkter irischer Kontakt — ohne Zwischenhandel</h3>
          <p>Sprechen Sie direkt mit Noel Murphy, unserem irischen Partner. Europäische Geschäftskultur, Englisch als Muttersprache, Ihre Zeitzone. Ein Anruf an <strong>WhatsApp</strong>.</p>
        </div>

        <div class="pillar">
          <div class="pillar-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h20"/><path d="M5 20V8l7-4 7 4v12"/><path d="M9 14h6"/><path d="M9 10h6"/></svg>
          </div>
          <h3>Mediterrane Logistik — schnell und zuverlässig</h3>
          <p>Direkte Verschiffung nach <strong>Rotterdam, Hamburg, Antwerpen, Genua, Barcelona und Felixstowe</strong>. Kürzere Transitzeiten als aus Indien oder dem Golf. Vollständige Exportdokumentation inklusive.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       INDUSTRIES SECTION
       ============================================================ -->
  <section class="industries" id="industries" aria-labelledby="industries-heading">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow on-dark">Anwendungsbranchen</span>
        <h2 id="industries-heading">Bewährt in sieben Schlüsselbranchen</h2>
        <p>Von EV-Batteriegehäusen bis zu Flugzeugstrukturen — unsere Masseln versorgen die anspruchsvollsten Anwendungen der europäischen Fertigung.</p>
      </div>

      <div class="industry-grid">

        <a href="/de/branchen/automotive/" class="industry">
          <span class="industry-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 17h14M5 17a2 2 0 0 1-2-2v-2l2-5a2 2 0 0 1 1.8-1.4L10 6h4l3.2.6A2 2 0 0 1 19 8l2 5v2a2 2 0 0 1-2 2"/><circle cx="7.5" cy="17" r="2"/><circle cx="16.5" cy="17" r="2"/></svg>
          </span>
          <span class="industry-name">Automobilindustrie</span>
          <span class="industry-desc">Motorblöcke, Radnaben, EV-Batteriegehäuse, tragende Karosseriebauteile.</span>
          <span class="arrow">Mehr →</span>
        </a>

        <a href="/de/branchen/luft-und-raumfahrt/" class="industry">
          <span class="industry-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>
          </span>
          <span class="industry-name">Luft- und Raumfahrt</span>
          <span class="industry-desc">Flugzeugbeplankungen, Strukturrahmen, hochfeste Legierungsanwendungen.</span>
          <span class="arrow">Mehr →</span>
        </a>

        <a href="/de/branchen/bauwesen/" class="industry">
          <span class="industry-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21V8l9-5 9 5v13"/><rect x="9" y="14" width="6" height="7"/></svg>
          </span>
          <span class="industry-name">Bauwesen</span>
          <span class="industry-desc">Fassadenprofile, Fenster- und Türrahmen, Dekorpaneele.</span>
          <span class="arrow">Mehr →</span>
        </a>

        <a href="/de/branchen/elektronik/" class="industry">
          <span class="industry-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M9 1v3M15 1v3M9 20v3M15 20v3M20 9h3M20 14h3M1 9h3M1 14h3"/></svg>
          </span>
          <span class="industry-name">Elektronik</span>
          <span class="industry-desc">Kühlkörper, Gerätegehäuse, leitfähige Steckverbinder.</span>
          <span class="arrow">Mehr →</span>
        </a>

        <a href="/de/branchen/verpackung/" class="industry">
          <span class="industry-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V12"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          </span>
          <span class="industry-name">Verpackung</span>
          <span class="industry-desc">Aluminiumdosen, Lebensmittel- und Pharma-Folien.</span>
          <span class="arrow">Mehr →</span>
        </a>

        <a href="/de/branchen/energie-und-verkehr/" class="industry">
          <span class="industry-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </span>
          <span class="industry-name">Energie & Verkehr</span>
          <span class="industry-desc">Kabel-Leiter, Leichtbauteile für den Schienenverkehr.</span>
          <span class="arrow">Mehr →</span>
        </a>

        <a href="/de/branchen/maschinenbau/" class="industry">
          <span class="industry-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
          </span>
          <span class="industry-name">Maschinenbau</span>
          <span class="industry-desc">Industrieanlagenteile, Formen, Automatisierungskomponenten.</span>
          <span class="arrow">Mehr →</span>
        </a>

      </div>
    </div>
  </section>

  <!-- ============================================================
       CBAM SECTION
       ============================================================ -->
  <section class="cbam" aria-labelledby="cbam-heading">
    <div class="container">
      <div class="cbam-inner">
        <div>
          <span class="eyebrow on-dark">EU-Compliance · 2026</span>
          <h2 id="cbam-heading">CBAM-pflichtig? Wir haben Sie abgesichert.</h2>
          <p>
            Der EU-Grenzausgleichsmechanismus (CBAM) ist in seiner endgültigen Phase aktiv. Als Ihr Aluminium-Lieferant
            liefern wir alle geprüften Emissionsdaten und Unterlagen, die Ihre CBAM-Meldung erfordert
            — in jede Lieferung integriert.
          </p>
          <a href="/de/cbam-leitfaden/" class="btn btn-primary">
            Unseren CBAM-Leitfaden lesen
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>

        <div class="cbam-stats" aria-label="CBAM-Eckdaten">
          <div class="cbam-stat">
            <strong>12.000+</strong>
            <span>In der EU registrierte CBAM-Anmelder</span>
          </div>
          <div class="cbam-stat">
            <strong>50 t</strong>
            <span>Jährliche Aluminium-Schwelle für die volle CBAM-Registrierung</span>
          </div>
          <div class="cbam-stat">
            <strong>31. Mai 2027</strong>
            <span>Erste CBAM-Zertifikatsabgabe (für Einfuhren in 2026)</span>
          </div>
          <div class="cbam-stat">
            <strong>Geprüft</strong>
            <span>Durch akkreditierte Dritte verifizierte Emissionsdaten</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FINAL CTA
       ============================================================ -->
  <section class="noel-section" aria-labelledby="noel-heading">
    <div class="container">
      <div class="noel-grid">
        <div class="noel-photo-wrapper">
          <div class="noel-photo-modern">
            <img src="/images/branding/brand-noel-murphy-portrait-01.webp" alt="Noel Murphy - Partner Europageschäft" class="noel-img-asset" />
            <span class="noel-flag">
              <span class="flag-ie" aria-hidden="true"><span></span><span></span><span></span></span>
              Irland
            </span>
            <div class="noel-photo-caption">
              <strong>Noel Murphy</strong>
              <span>Partner — Europageschäft</span>
            </div>
          </div>
        </div>

        <div class="noel-content">
          <span class="eyebrow">Ihr direkter europäischer Ansprechpartner</span>
